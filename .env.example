# Bot
PCCA_TELEGRAM_BOT_TOKEN=

# Runtime
PCCA_TIMEZONE=UTC
PCCA_NIGHTLY_CRON=0 1 * * *
PCCA_MORNING_CRON=30 8 * * *
PCCA_LOG_LEVEL=INFO

# Storage
PCCA_DATA_DIR=.pcca
PCCA_DB_PATH=.pcca/pcca.db
PCCA_BROWSER_PROFILES_DIR=.pcca/browser_profiles
PCCA_BROWSER_HEADLESS=true
PCCA_BROWSER_HEADFUL_PLATFORMS=x,linkedin
# Use installed Chrome by default for account login. Set to bundled to use Playwright Chromium.
PCCA_BROWSER_CHANNEL=chrome

# Browser session refresh
PCCA_SESSION_REFRESH_ENABLED=true
PCCA_SESSION_REFRESH_COOLDOWN_SECONDS=1800
# Optional: chrome, arc, brave, or edge. Empty means auto-detect.
PCCA_SESSION_REFRESH_BROWSER=

PCCA_OLLAMA_ENABLED=false
PCCA_OLLAMA_BASE_URL=http://localhost:11434
# Multilingual default for EN/UK/RU reranking lane.
PCCA_OLLAMA_MODEL=qwen2.5:7b
